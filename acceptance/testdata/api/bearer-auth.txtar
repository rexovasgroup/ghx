# By default, requests use token authentication scheme
env GH_DEBUG=api
exec gh api /user
stderr '> Authorization: token'

# When bearer_auth config setting is enabled, requests use Bearer authentication scheme
exec gh config set bearer_auth enabled
exec gh api /user
stderr '> Authorization: Bearer'

# Reset config for next test
exec gh config set bearer_auth disabled

# When GH_BEARER_AUTH env var is set, requests use Bearer authentication scheme
env GH_BEARER_AUTH=1
exec gh api /user
stderr '> Authorization: Bearer'

# Auth status also respects GH_BEARER_AUTH env var
exec gh auth status
stderr '> Authorization: Bearer'
