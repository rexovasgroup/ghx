#!/bin/bash

# Manage go-licenses version externally for CI
if [ "$CI" != "true" ]; then
    go install github.com/google/go-licenses/v2@latest
fi

# Verify go-licenses is available
if ! command -v go-licenses &> /dev/null; then
    echo "Error: go-licenses is not installed or not on PATH"
    exit 1
fi

# Setup temporary directory to collect updated third-party source code
export TEMPDIR="$(mktemp -d)"
trap "rm -fr ${TEMPDIR}" EXIT

# Clear stale license files and third-party source code
rm -f third-party-licenses.*.md
rm -rf third-party
mkdir -p third-party

# Define GOOS and their corresponding GOARCH values based on .goreleaser.yml
declare -A platform_archs=(
    ["linux"]="386 arm amd64 arm64"
    ["darwin"]="amd64 arm64"
    ["windows"]="386 amd64 arm64"
)

for goos in linux darwin windows ; do
    for goarch in ${platform_archs[$goos]} ; do
        # Note: we ignore warnings because we want the command to succeed, however the output should be checked
        #       for any new warnings, and potentially we may need to add license information.
        #
        #       Normally these warnings are packages containing non go code, which may or may not require explicit attribution,
        #       depending on the license.
        echo "Generating licenses for ${goos}/${goarch}..."
        GOOS="${goos}" GOARCH="${goarch}" go-licenses save ./... --save_path="${TEMPDIR}/${goos}-${goarch}" --force || echo "Ignore warnings"
        GOOS="${goos}" GOARCH="${goarch}" go-licenses report ./... --template .github/licenses.tmpl --ignore github.com/cli/cli > third-party-licenses.${goos}-${goarch}.md || echo "Ignore warnings"
        cp -fR "${TEMPDIR}/${goos}-${goarch}"/* third-party/
    done
done

echo "Licenses generated for all platforms."
